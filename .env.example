# Seva Mining — AI Social Media Agency
# Copy to .env and fill in secrets. Scheduler reads the same file via scheduler/.env (symlink).

# ── Required: Core infra ────────────────────────────────────────────────────
# Neon Postgres — use -pooler endpoint. asyncpg strips sslmode param; keep it anyway for psql compatibility.
DATABASE_URL=postgresql+asyncpg://user:pass@host-pooler.region.aws.neon.tech/neondb?sslmode=require

# Anthropic Claude API (all agents: drafting + compliance)
ANTHROPIC_API_KEY=

# ── Required: Auth (Phase 8) ────────────────────────────────────────────────
# HS256 signing key — MUST be >=32 bytes. Generate: openssl rand -hex 32
JWT_SECRET=
# Dashboard login — bcrypt hash of the password (not the plaintext). Generate:
#   python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your-password'))"
DASHBOARD_PASSWORD=

# ── Required: Agent APIs ────────────────────────────────────────────────────
# X (Twitter) API — Basic tier ($100/mo), read-only
X_API_BEARER_TOKEN=
# Optional X OAuth1.0a keys (only if the agent needs user-context endpoints)
X_API_KEY=
X_API_SECRET=

# SerpAPI — Google News + historical pattern verification
SERPAPI_API_KEY=

# ── Optional: WhatsApp delivery (Twilio) ───────────────────────────────────
# Outbound Senior Agent digest + alerts. Leave empty to disable WhatsApp delivery.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
DIGEST_WHATSAPP_TO=whatsapp:+1XXXXXXXXXX

# ── Optional: Image rendering (Phase 11) ───────────────────────────────────
# Gemini Imagen for infographic/quote rendering + Cloudflare R2 for object storage
GEMINI_API_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ── Required for content agent market snapshot grounding (quick-260420-oa1) ─
# FRED (Federal Reserve St. Louis) — macro stack (10Y nominal, 10Y real, Fed funds, CPI).
# Free, instant key: https://fredaccount.stlouisfed.org/ → API Keys → Request API Key.
FRED_API_KEY=
# metalpriceapi.com — spot gold + silver. Basic plan $8.99/mo, 10k req/mo.
# Sign up: https://metalpriceapi.com/ → Basic plan → Dashboard.
METALPRICEAPI_API_KEY=

# ── Dev ─────────────────────────────────────────────────────────────────────
# Frontend URL used by backend CORS + email links. Production: https://<your-domain>
FRONTEND_URL=http://localhost:5173
