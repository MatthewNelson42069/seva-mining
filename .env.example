# Seva Mining — AI Social Media Agency
# Copy this file to .env and fill in your values

# Database (Neon — use pooled connection string with -pooler hostname)
DATABASE_URL=postgresql+asyncpg://user:pass@host-pooler.region.aws.neon.tech/neondb?sslmode=require

# X (Twitter) API — Basic tier ($100/mo)
X_API_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=

# Apify — Instagram scraper
APIFY_API_TOKEN=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Resend — Email delivery
RESEND_API_KEY=

# Google News via SerpAPI
GOOGLE_NEWS_API_KEY=

# Reddit API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=seva-mining-agent/1.0

# Notifications
DIGEST_EMAIL_TO=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Frontend
FRONTEND_URL=http://localhost:5173
